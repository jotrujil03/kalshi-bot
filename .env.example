# Kalshi API credentials
# Get your API key ID from https://kalshi.com/profile/api-keys
KALSHI_API_KEY_ID=your_api_key_id_here

# Path to your RSA private key PEM file
# Generate with: openssl genrsa -out private_key.pem 2048
# Then register the public key at https://kalshi.com/profile/api-keys
KALSHI_PRIVATE_KEY_PATH=./private_key.pem

# Environment: "demo" (paper trading) or "live" (real money)
KALSHI_ENVIRONMENT=demo

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum number of contracts to buy per trade
MAX_POSITION_SIZE=10

# Minimum signal confidence required to place a trade (0.0 - 1.0)
MIN_CONFIDENCE=0.6

# Max USD to risk per trade (contracts are typically $0.01 - $0.99 each)
MAX_TRADE_USD=50
